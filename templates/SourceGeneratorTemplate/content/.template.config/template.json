{
    "$schema": "http://json.schemastore.org/template",
    "author": "CN innovation",
    "classifications": [
        "Source Generator",
        "Roslyn",
        "Code Generation",
        "C#",
        "Testing",
        "xUnit"
    ],
    "identity": "CNinnovation.Templates.SourceGenerator",
    "name": ".NET Source Generator Template with xUnit v3 and Snapshot Testing",
    "shortName": "sourcegen",
    "description": "A template that scaffolds a .NET source generator project with a unit test project using xUnit v3 and integrated snapshot testing via Verify.",
    "tags": {
        "language": "C#",
        "type": "project"
    },
    "sourceName": "MyGenerator",
    "preferNameDirectory": true,
    "symbols": {
        "Framework": {
            "type": "parameter",
            "description": "The target framework for the test projects.",
            "datatype": "choice",
            "choices": [
                {
                    "choice": "net9.0",
                    "description": ".NET 9.0"
                },
                {
                    "choice": "net10.0",
                    "description": ".NET 10.0"
                }
            ],
            "defaultValue": "net10.0",
            "replaces": "net10.0"
        },
        "GeneratorFramework": {
            "type": "parameter",
            "description": "The target framework for the source generator project.",
            "datatype": "choice",
            "choices": [
                {
                    "choice": "netstandard2.0",
                    "description": ".NET Standard 2.0"
                },
                {
                    "choice": "net8.0",
                    "description": ".NET 8.0"
                },
                {
                    "choice": "net9.0",
                    "description": ".NET 9.0"
                },
                {
                    "choice": "net10.0",
                    "description": ".NET 10.0"
                }
            ],
            "defaultValue": "netstandard2.0",
            "replaces": "net8.0"
        },
        "IsNetStandard20": {
            "type": "computed",
            "value": "(GeneratorFramework == \"netstandard2.0\")"
        },
        "IncludeTests": {
            "type": "parameter",
            "datatype": "bool",
            "defaultValue": "true",
            "description": "Include unit test project",
            "shortName": "t"
        },
        "IncludeSnapshotTests": {
            "type": "parameter",
            "datatype": "bool",
            "defaultValue": "true",
            "description": "Include snapshot test project",
            "shortName": "s"
        },
        "SyntaxProviderMode": {
            "type": "parameter",
            "description": "The syntax provider approach used to detect annotated types in the source generator. 'CreateSyntaxProvider' is general-purpose and flexible. 'ForAttributeWithMetadataName' is optimized for attribute-driven generators and is the recommended approach when generation is triggered by a known attribute.",
            "datatype": "choice",
            "shortName": "m",
            "choices": [
                {
                    "choice": "CreateSyntaxProvider",
                    "description": "General-purpose approach using CreateSyntaxProvider. Suitable for any syntax-based detection."
                },
                {
                    "choice": "ForAttributeWithMetadataName",
                    "description": "Optimized for attribute-based generators. Uses ForAttributeWithMetadataName which is more efficient and precise."
                }
            ],
            "defaultValue": "CreateSyntaxProvider"
        },
        "UseForAttributeWithMetadataName": {
            "type": "computed",
            "value": "(SyntaxProviderMode == \"ForAttributeWithMetadataName\")"
        }
    },
    "sources": [
        {
            "modifiers": [
                {
                    "condition": "(!IncludeTests)",
                    "exclude": [ "MyGenerator.Tests/**/*" ]
                },
                {
                    "condition": "(!IncludeSnapshotTests)",
                    "exclude": [ "MyGenerator.SnapshotTests/**/*" ]
                }
            ]
        }
    ]
}
